DATABASE_URL=postgresql://user:password@host:5432/dbname
# Same signing key as the Host's JWT_SECRET (organize-me repo) - Event Creator only verifies,
# never issues, so this must match exactly in every shared environment.
JWT_SECRET=change-me-to-the-same-value-as-the-hosts-jwt-secret

# Slice R7 - Storage tab OAuth connect flows. Empty/unset is fine for most local dev (the routes
# that need them fail with a clear 503/RuntimeError rather than 500ing); only required to actually
# exercise a live Google Drive / Dropbox connection.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Fixed per-environment (issue #200) - must exactly match a redirect URI registered on the Google
# OAuth client in Google Cloud Console (Error 400: redirect_uri_mismatch otherwise).
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8080/api/v1/storage-config/google-drive/callback
DROPBOX_OAUTH_CLIENT_ID=
DROPBOX_OAUTH_CLIENT_SECRET=
# Fernet key encrypting stored storage credentials at rest - generate with
# `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`.
ENCRYPTION_KEY=

# --- Notifications (processing-run success/failure) ---
# Same Resend account as the Host (organize-me repo)'s RESEND_API_KEY.
RESEND_API_KEY=
# Verified custom domain sender - see app/core/config.py for why this must not be
# onboarding@resend.dev (Resend's sandbox sender only delivers to the account owner).
EMAIL_FROM=OrganizeMe <onboarding@organizeme.russcoopersoftware.com>
# Same Twilio account as the Host (organize-me repo)'s TWILIO_* credentials.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
