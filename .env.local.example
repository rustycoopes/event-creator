DATABASE_URL=postgresql://user:password@host:5432/dbname
# Same signing key as the Host's JWT_SECRET (organize-me repo) - Event Creator only verifies,
# never issues, so this must match exactly in every shared environment.
JWT_SECRET=change-me-to-the-same-value-as-the-hosts-jwt-secret

# Slice R7 - Storage tab OAuth connect flows. Empty/unset is fine for most local dev (the routes
# that need them fail with a clear 503/RuntimeError rather than 500ing); only required to actually
# exercise a live Google Drive / Dropbox connection.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
DROPBOX_OAUTH_CLIENT_ID=
DROPBOX_OAUTH_CLIENT_SECRET=
# Fernet key encrypting stored storage credentials at rest - generate with
# `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`.
ENCRYPTION_KEY=
